# TinaCMS Configuration
# =====================
# Copy this file to .env and fill in your values

# TinaCMS Client ID (required)
# Get this from https://app.tina.io/register
TINA_CLIENT_ID=your-client-id-here

# TinaCMS Token (optional - only for Tina Cloud)
# Leave empty if using Git-based workflow without Tina Cloud
TINA_TOKEN=
